{
  "name": "rembg-photopea",
  "version": "1.0.0",
  "description": "Remove backgrounds in Photopea using rembg",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-backend": "bash build-backend.sh",
    "dist": "npm run build-backend && electron-builder",
    "dist:linux": "npm run build-backend && electron-builder --linux",
    "dist:win": "npm run build-backend && electron-builder --win",
    "dist:mac": "npm run build-backend && electron-builder --mac"
  },
  "build": {
    "appId": "com.rembg.photopea",
    "productName": "Rembg for Photopea",
    "files": [
      "main.js",
      "preload.js",
      "splash.html",
      "icon.svg"
    ],
    "extraResources": [
      {
        "from": "backend-dist/",
        "to": "backend",
        "filter": ["**/*"]
      },
      {
        "from": "../plugin/",
        "to": "plugin",
        "filter": ["**/*"]
      },
      {
        "from": "../.certs/",
        "to": "certs",
        "filter": ["*.pem"]
      }
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Graphics",
      "icon": "icon.svg"
    },
    "win": {
      "target": ["nsis"],
      "icon": "icon.svg"
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.graphics-design",
      "icon": "icon.svg"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
